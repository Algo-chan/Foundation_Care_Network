{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "../../",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "shared/*": ["../../packages/shared/*"],
      "database/*": ["../../packages/database/*"]
    }
  },
  "include": ["src/**/*"]
}
